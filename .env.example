# CHUNK_SIZE=800
# CHUNK_OVERLAP=150
# RETRIEVAL_K=10
# RRF_K_CONSTANT=60
# ANALYZER_RELEVANCE_FLOOR=0.40
# MIN_CITATION_COVERAGE=0.55
# MIN_CITATION_UTILIZATION=0.30
# MAX_WORKFLOW_RETRIES=1      # set to 0 on demo day to save API credits
# RESEARCH_TIMEOUT_SECONDS=120
