# ResearchMind Environment Configuration
# Copy this file to .env and fill in your API keys.

# Groq API key (required for LLM inference)
# Get one at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key (optional, for alternative LLM provider)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Storage (persistence for ephemeral filesystems like Render)
# Required to prevent data loss on container restarts. Free tier: 1GB, no CC required.
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_key
SUPABASE_BUCKET=your_supabase_bucket_name
